# =============================================================================
# Cebu's Ayers Lechon — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Get this from: Supabase Dashboard > Settings > Database > Connection string
# Use the "Transaction" pooler connection string for serverless (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# -----------------------------------------------------------------------------
# Supabase (Storage for image uploads)
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Generate a strong random secret (min 32 characters):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-strong-random-secret-min-32-chars"

# -----------------------------------------------------------------------------
# Upstash Redis (Rate Limiting)
# -----------------------------------------------------------------------------
# Get these from: https://console.upstash.com/ (create a Redis database)
# Or via Vercel Integration: https://vercel.com/integrations/upstash
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Resend (Email Notifications)
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
# Admin email receives feedback notifications
RESEND_API_KEY=""
ADMIN_NOTIFICATION_EMAIL="admin@ayerlechon.com"

# -----------------------------------------------------------------------------
# CORS (Optional)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. Leave empty to allow all origins.
# Example: "https://ayerlechon.com,https://www.ayerlechon.com"
ALLOWED_ORIGINS=""
